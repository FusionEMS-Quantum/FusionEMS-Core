ENVIRONMENT=development
AUTH_MODE=local
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/fusionems
REDIS_URL=redis://localhost:6379/0
OPA_URL=http://localhost:8181
OTEL_ENABLED=false
JWT_SECRET_KEY=dev_jwt_secret_32_chars_minimum00
SYSTEM_TENANT_ID=00000000-0000-0000-0000-000000000000
S3_BUCKET_DOCS=
S3_BUCKET_EXPORTS=

# Stripe Payment Integration
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# OpenAI
OPENAI_API_KEY=

# Telnyx Voice/SMS/Fax Integration
TELNYX_API_KEY=
TELNYX_FROM_NUMBER=
TELNYX_MESSAGING_PROFILE_ID=
TELNYX_PUBLIC_KEY=
TELNYX_WEBHOOK_TOLERANCE_SECONDS=300
CENTRAL_BILLING_PHONE_E164=+18005550123
CNAM_DISPLAY_NAME=FusionEMS Quantum
CNAM_STATUS=
FOUNDER_BILLING_ESCALATION_PHONE_E164=+18005550999

# Open-source voice + telephony controls
OSS_TTS_PROMPT_DIR=/tmp/fusionems_voice_prompts
OSS_TTS_ENGINE_PRIMARY=xtts
OSS_TTS_ENGINE_FALLBACK=piper
OSS_TTS_XTTS_BIN=tts
OSS_TTS_XTTS_MODEL_NAME=tts_models/multilingual/multi-dataset/xtts_v2
OSS_TTS_XTTS_LANGUAGE=en
OSS_TTS_XTTS_SPEAKER_WAV=
OSS_TTS_PIPER_BIN=piper
OSS_TTS_PIPER_MODEL_PATH=
OSS_TTS_PIPER_CONFIG_PATH=
OSS_TTS_PIPER_SPEAKER_ID=
OSS_STT_ENGINE=faster_whisper
OSS_STT_MODEL_SIZE=small
BILLING_TELEPHONY_ENGINE=telnyx
BILLING_TELEPHONY_CONTROL_URL=
BILLING_TELEPHONY_CONTROL_TOKEN=

# Office Ally SFTP Integration
OFFICEALLY_SFTP_HOST=
OFFICEALLY_SFTP_PORT=22
OFFICEALLY_SFTP_USERNAME=
OFFICEALLY_SFTP_PASSWORD=
OFFICEALLY_SFTP_REMOTE_DIR=/

# Lob Mail Integration
LOB_API_KEY=
LOB_WEBHOOK_SECRET=

# Microsoft Entra User Login (Authorization Code Flow)
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_FOUNDER_EMAIL=
MICROSOFT_REDIRECT_URI=http://localhost:8000/api/v1/auth/microsoft/callback
MICROSOFT_POST_LOGIN_URL=http://localhost:3000/dashboard
MICROSOFT_FOUNDER_POST_LOGIN_URL=http://localhost:3000/dashboard?next=%2Ffounder
MICROSOFT_POST_LOGOUT_URL=http://localhost:3000/login

# Optional: Explicit frontend base URL for public redirects (Stripe success/cancel).
# If unset, the backend derives it from MICROSOFT_POST_LOGIN_URL.
FRONTEND_BASE_URL=http://localhost:3000
